# ============================================================
# PropOrata API Server — Environment Variables
# Copy this to .env and fill in your values for local dev.
# All of these must also be set in Railway → Service → Variables.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=8080

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Database ---
# Local: postgresql://localhost:5432/proporata
# Railway: use ${{Postgres.DATABASE_URL}} in Railway Variables
DATABASE_URL=postgresql://localhost:5432/proporata

# --- Cloudflare R2 Object Storage ---
# Endpoint:  https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Tokens: R2 → Manage API Tokens → Create Token (Object Read & Write, both buckets)
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_FILES_BUCKET=proporata-files
R2_PRIVATE_BUCKET=proporata-private
# Public URL: R2 → proporata-files bucket → Settings → Public Access → R2.dev subdomain
R2_PUBLIC_URL=https://pub-XXXX.r2.dev

# --- App ---
PUBLIC_APP_URL=http://localhost:8080
ADMIN_PASSWORD=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
CAL_SMS_ENABLED=false

# --- Google OAuth / Drive ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/integrations/google-drive/callback

# --- OpenAI (OCR / AI features) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Demo / Seeding (optional) ---
SEED_DEMO_DATA=
SEED_DEMO_ALLOW_NO_STORAGE=
LOG_LEVEL=info
