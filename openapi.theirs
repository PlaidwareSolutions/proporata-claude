        name: { type: string }
        size: { type: integer }
        contentType: { type: string, nullable: true }
        storageKey: { type: string }
        uploadedByUserId: { type: integer, nullable: true }
        uploadedByName: { type: string }
        uploadedAt: { type: string }
      required: [id, eventId, name, size, storageKey, uploadedByName, uploadedAt]

    RegisterCalendarAttachmentBody:
      type: object
      properties:
        name: { type: string }
        size: { type: integer }
        contentType: { type: string }
        storageKey: { type: string }
      required: [name, storageKey]

    CalendarEvent:
      type: object
      properties:
        id: { type: integer }
        subCalendarId: { type: integer }
        subCalendarSlug: { type: string }
        color: { type: string }
        title: { type: string }
        body: { type: string }
        startsAt: { type: string }
        endsAt: { type: string }
        allDay: { type: boolean }
        locationText: { type: string, nullable: true }
        locationUrl: { type: string, nullable: true }
        resourceId: { type: integer, nullable: true }
        capacity: { type: integer, nullable: true }
        recurrence:
          $ref: "#/components/schemas/CalendarRecurrence"
        exceptions:
          type: array
          items: { type: string }
        overrides:
          type: array
          items:
            $ref: "#/components/schemas/CalendarOverride"
        source: { type: string, nullable: true }
        sourceRefType: { type: string, nullable: true }
        sourceRefId: { type: string, nullable: true }
        cancelled: { type: boolean }
        createdByUserId: { type: integer, nullable: true }
        createdByName: { type: string }
        createdAt: { type: string }
        updatedAt: { type: string }
      required: [id, subCalendarId, subCalendarSlug, color, title, body, startsAt, endsAt, allDay, exceptions, overrides, cancelled, createdByName, createdAt, updatedAt]

    CalendarEventInstance:
      allOf:
        - $ref: "#/components/schemas/CalendarEvent"
        - type: object
          properties:
            instanceId: { type: string }
            occurrenceKey: { type: string }
          required: [instanceId, occurrenceKey]

    CalendarEventDetail:
      allOf:
