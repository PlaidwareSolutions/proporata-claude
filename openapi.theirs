        "201":
          description: Created
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CalendarResource"

  /calendar/resources/{id}:
    patch:
      operationId: updateCalendarResource
      tags: [calendar]
      parameters:
        - name: id
          in: path
          required: true
          schema: { type: integer }
      requestBody:
        required: true
        content:
          application/json:
            schema:
