        action: { type: string }
        actorUserId: { type: integer, nullable: true }
        actorName: { type: string }
        diff: {}
        createdAt: { type: string }
      required: [id, eventId, action, actorName, createdAt]

    CreateCalendarEventBody:
      type: object
      properties:
        subCalendarId: { type: integer }
        title: { type: string }
        body: { type: string }
        startsAt: { type: string }
        endsAt: { type: string }
        allDay: { type: boolean }
        locationText: { type: string, nullable: true }
        locationUrl: { type: string, nullable: true }
        resourceId: { type: integer, nullable: true }
        capacity: { type: integer, nullable: true }
