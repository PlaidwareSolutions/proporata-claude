      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CalendarResource"
    delete:
      operationId: deleteCalendarResource
      tags: [calendar]
      parameters:
        - name: id
          in: path
          required: true
          schema: { type: integer }
