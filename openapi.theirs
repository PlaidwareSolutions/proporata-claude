        description: { type: string }
        capacity: { type: integer, nullable: true }
        active: { type: boolean }
        sortOrder: { type: integer }
      required: [name]

    UpdateCalendarResourceBody:
      type: object
      properties:
        name: { type: string }
        description: { type: string }
        capacity: { type: integer, nullable: true }
        active: { type: boolean }
        sortOrder: { type: integer }

