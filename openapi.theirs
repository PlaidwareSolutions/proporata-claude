      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CalendarPrefs"

  /calendar/me/ical-token:
    post:
      operationId: rotateCalendarIcalToken
      tags: [calendar]
      summary: Generate or rotate my personal iCal subscription token
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                type: object
                properties:
                  icalToken: { type: string }
                  icalTokenCreatedAt: { type: string }
                required: [icalToken, icalTokenCreatedAt]

  /calendar/events:
    get:
      operationId: listCalendarEvents
      tags: [calendar]
      summary: List expanded event instances within a window
      parameters:
        - name: from
          in: query
          required: true
          schema: { type: string }
        - name: to
          in: query
          required: true
          schema: { type: string }
        - name: search
          in: query
          required: false
          schema: { type: string }
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                type: array
