  /calendar/me/prefs:
    get:
      operationId: getCalendarPrefs
      tags: [calendar]
      summary: Get my calendar preferences
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CalendarPrefs"
    patch:
      operationId: updateCalendarPrefs
      tags: [calendar]
      summary: Update my calendar preferences
      requestBody:
        required: true
