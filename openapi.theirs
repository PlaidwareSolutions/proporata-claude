          $ref: "#/components/schemas/CalendarRsvpCounts"
        myRsvp:
          type: string
          nullable: true
        entries:
          type: array
          items: { $ref: "#/components/schemas/CalendarRsvpEntry" }
      required: [eventId, occurrenceKey, counts, entries]

    SetCalendarRsvpBody:
      type: object
      properties:
        status:
          type: string
          enum: [yes, no, maybe]
        occurrenceKey: { type: string }
      required: [status]

    CalendarExternalFeed:
      type: object
      properties:
        id: { type: integer }
        subCalendarId: { type: integer }
