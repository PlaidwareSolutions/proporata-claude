openapi: 3.1.0
info:
  title: Api
  version: 0.1.0
  description: API specification
servers:
  - url: /api
    description: Base API path
tags:
  - name: health
    description: Health operations
  - name: auth
    description: Authentication operations
  - name: users
    description: User management operations
  - name: buildings
    description: Building operations
  - name: units
    description: Unit operations
  - name: work-orders
    description: Work order operations
  - name: insurance
    description: Insurance policy operations
  - name: documents
    description: Document operations
  - name: vendors
    description: Vendor operations
  - name: settings
    description: Settings operations
  - name: storage
    description: Object storage upload and serving endpoints
  - name: integrations
    description: Third-party integration operations
  - name: notifications
    description: Notification operations
  - name: communications
    description: Communications and broadcast operations
  - name: reports
    description: Reporting and analytics operations
  - name: billing
    description: Owner accounts and ledger operations
  - name: motions
    description: Owner accounts and ledger operations
  - name: calendar
    description: Board motions and voting operations
  - name: meetings
    description: Board meeting CRUD, agendas, attendance, lifecycle, minutes, PDFs, and ICS feeds
  - name: governance
    description: Organization-level governance settings (notice and quorum)
paths:
  /healthz:
    get:
      operationId: healthCheck
      tags: [health]
      summary: Health check
      description: Returns server health status
      responses:
        "200":
          description: Healthy
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/HealthStatus"

  /auth/login:
    post:
      operationId: login
      tags: [auth]
      summary: Login with email and password
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/LoginBody"
      responses:
        "200":
          description: Authenticated user
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/AuthResponse"
        "401":
          description: Invalid credentials

  /auth/logout:
    post:
      operationId: logout
      tags: [auth]
      summary: Logout and clear session cookie
      responses:
        "200":
          description: Logged out
          content:
            application/json:
              schema:
                type: object
                properties:
                  ok:
                    type: boolean
                required:
                  - ok

  /auth/me:
    get:
      operationId: getMe
      tags: [auth]
      summary: Get the currently authenticated user
      security:
        - cookieAuth: []
      responses:
        "200":
          description: Current user
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/AuthResponse"
        "401":
          description: Unauthorized

  /users:
    get:
      operationId: listUsers
      tags: [users]
      summary: List all users (admin only)
      security:
        - cookieAuth: []
      responses:
        "200":
          description: List of users
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/User"
        "401":
          description: Unauthorized
        "403":
          description: Forbidden

  /users/invite:
    post:
      operationId: inviteUser
      tags: [users]
      summary: Invite a new user (admin only)
      security:
        - cookieAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/InviteUserBody"
      responses:
        "201":
          description: Created user
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/User"
        "401":
          description: Unauthorized
        "403":
          description: Forbidden
        "409":
          description: Email already exists

  /users/{id}/role:
    patch:
      operationId: updateUserRole
      tags: [users]
      summary: Update a user's role (admin only)
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateRoleBody"
      responses:
        "200":
          description: Updated user
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/User"
        "401":
          description: Unauthorized
        "403":
          description: Forbidden
        "404":
          description: Not found
        "409":
          description: Cannot demote the last remaining Admin

  /users/{id}:
    delete:
      operationId: deleteUser
      tags: [users]
      summary: Delete a user (admin only)
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "204":
          description: Deleted
        "401":
          description: Unauthorized
        "403":
          description: Forbidden
        "404":
          description: Not found

  /users/{id}/board-member:
    patch:
      operationId: updateUserBoardMember
      tags: [users]
      summary: Toggle the board-member flag on a user (admin only)
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateBoardMemberBody"
      responses:
        "200":
          description: Updated user
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/User"
        "401":
          description: Unauthorized
        "403":
          description: Forbidden
        "404":
          description: Not found
        "409":
          description: Cannot remove the last remaining board member

  /users/{id}/board-member-history:
    get:
      operationId: listUserBoardMemberHistory
      tags: [users]
      summary: List the audit history of board-flag changes for a user (admin only)
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: Audit entries, newest first
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/BoardMemberAuditEntry"
        "401":
          description: Unauthorized
        "403":
          description: Forbidden
        "404":
          description: Not found

  /users/{id}/officer:
    patch:
      operationId: updateUserOfficer
      tags: [users]
      summary: Set officer title and/or term dates on a board member (admin only)
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateOfficerBody"
      responses:
        "200":
          description: Updated user
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/User"
        "400":
          description: Invalid input or user is not a board member
        "401":
          description: Unauthorized
        "403":
          description: Forbidden
        "404":
          description: Not found
        "409":
          description: Officer title already held by another user

  /board/history:
    get:
      operationId: listBoardHistory
      tags: [users]
      summary: List board membership and officer change history
      security:
        - cookieAuth: []
      responses:
        "200":
          description: History entries (most recent first)
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/BoardHistoryEntry"
        "401":
          description: Unauthorized
        "403":
          description: Forbidden

  /board/at:
    get:
      operationId: getBoardAtDate
      tags: [users]
      summary: List board members active on a given date (defaults to today)
      security:
        - cookieAuth: []
      parameters:
        - name: date
          in: query
          required: false
          schema:
            type: string
          description: ISO date YYYY-MM-DD. Defaults to today.
      responses:
        "200":
          description: Roster active on the given date
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/BoardRosterResponse"
        "400":
          description: Invalid date
        "401":
          description: Unauthorized
        "403":
          description: Forbidden

  /users/{id}/unit:
    patch:
      operationId: assignUserUnit
      tags: [users]
      summary: Assign a unit to a resident user (admin only)
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/AssignUnitBody"
      responses:
        "200":
          description: Updated user
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/User"
        "401":
          description: Unauthorized
        "403":
          description: Forbidden
        "404":
          description: Not found

  /buildings:
    get:
      operationId: listBuildings
      tags: [buildings]
      summary: List all buildings
      security:
        - cookieAuth: []
      responses:
        "200":
          description: List of buildings
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/Building"
    post:
      operationId: createBuilding
      tags: [buildings]
      summary: Create a building
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateBuildingBody"
      responses:
        "201":
          description: Created building
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Building"

  /buildings/{id}:
    get:
      operationId: getBuilding
      tags: [buildings]
      summary: Get a building by number
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: Building
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Building"
        "404":
          description: Not found
    patch:
      operationId: updateBuilding
      tags: [buildings]
      summary: Update a building
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateBuildingBody"
      responses:
        "200":
          description: Updated building
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Building"
        "404":
          description: Not found
    delete:
      operationId: deleteBuilding
      tags: [buildings]
      summary: Delete a building
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "204":
          description: Deleted
        "404":
          description: Not found

  /units:
    get:
      operationId: listUnits
      tags: [units]
      summary: List all units
      security:
        - cookieAuth: []
      parameters:
        - name: building
          in: query
          required: false
          schema:
            type: integer
      responses:
        "200":
          description: List of units
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/Unit"
    post:
      operationId: createUnit
      tags: [units]
      summary: Create a unit
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateUnitBody"
      responses:
        "201":
          description: Created unit
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Unit"

  /units/{id}:
    get:
      operationId: getUnit
      tags: [units]
      summary: Get a unit by ID
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      responses:
        "200":
          description: Unit
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Unit"
        "404":
          description: Not found
    patch:
      operationId: updateUnit
      tags: [units]
      summary: Update a unit
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateUnitBody"
      responses:
        "200":
          description: Updated unit
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Unit"
        "404":
          description: Not found
    delete:
      operationId: deleteUnit
      tags: [units]
      summary: Delete a unit
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      responses:
        "204":
          description: Deleted
        "404":
          description: Not found

  /work-orders:
    get:
      operationId: listWorkOrders
      tags: [work-orders]
      summary: List all work orders
      security:
        - cookieAuth: []
      parameters:
        - name: status
          in: query
          required: false
          schema:
            type: string
        - name: building
          in: query
          required: false
          schema:
            type: integer
      responses:
        "200":
          description: List of work orders
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/WorkOrder"
    post:
      operationId: createWorkOrder
      tags: [work-orders]
      summary: Create a work order
      security:
        - cookieAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateWorkOrderBody"
      responses:
        "201":
          description: Created work order
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/WorkOrder"

  /work-orders/{id}:
    get:
      operationId: getWorkOrder
      tags: [work-orders]
      summary: Get a work order by ID
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      responses:
        "200":
          description: Work order
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/WorkOrder"
        "404":
          description: Not found
    patch:
      operationId: updateWorkOrder
      tags: [work-orders]
      summary: Update a work order
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateWorkOrderBody"
      responses:
        "200":
          description: Updated work order
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/WorkOrder"
        "404":
          description: Not found
    delete:
      operationId: deleteWorkOrder
      tags: [work-orders]
      summary: Delete a work order
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      responses:
        "204":
          description: Deleted
        "404":
          description: Not found

  /work-orders/{id}/events:
    get:
      operationId: listWorkOrderEvents
      tags: [work-orders]
      summary: List events and attachments for a work order
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      responses:
        "200":
          description: Events with attachments
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/WorkOrderActivity"
        "403":
          description: Access denied
        "404":
          description: Not found

  /work-orders/{id}/comments:
    post:
      operationId: createWorkOrderComment
      tags: [work-orders]
      summary: Add a comment to a work order
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateWorkOrderCommentBody"
      responses:
        "201":
          description: Comment created
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/WorkOrderEvent"
        "403":
          description: Access denied
        "404":
          description: Not found

  /work-orders/{id}/comments/{eventId}:
    patch:
      operationId: updateWorkOrderComment
      tags: [work-orders]
      summary: Edit an existing comment (author or manager moderation)
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
        - name: eventId
          in: path
          required: true
          schema:
            type: integer
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateWorkOrderCommentBody"
      responses:
        "200":
          description: Comment updated
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/WorkOrderEvent"
        "403":
          description: Access denied
        "404":
          description: Not found
    delete:
      operationId: deleteWorkOrderComment
      tags: [work-orders]
      summary: Soft-delete a comment (author or manager)
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
        - name: eventId
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: Comment deleted
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/WorkOrderEvent"
        "403":
          description: Access denied
        "404":
          description: Not found

  /work-orders/{id}/attachments:
    post:
      operationId: createWorkOrderAttachment
      tags: [work-orders]
      summary: Register an uploaded photo as a work-order attachment
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateWorkOrderAttachmentBody"
      responses:
        "201":
          description: Attachment registered
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/WorkOrderAttachment"
        "403":
          description: Access denied
        "404":
          description: Not found

  /work-orders/{id}/attachments/{attId}:
    delete:
      operationId: deleteWorkOrderAttachment
      tags: [work-orders]
      summary: Delete a work-order attachment (manager only)
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
        - name: attId
          in: path
          required: true
          schema:
            type: integer
      responses:
        "204":
          description: Deleted
        "403":
          description: Access denied
        "404":
          description: Not found

  /insurance:
    get:
      operationId: listInsurance
      tags: [insurance]
      summary: List all insurance policies
      security:
        - cookieAuth: []
      responses:
        "200":
          description: List of insurance policies
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/InsurancePolicy"

  /insurance/{id}:
    get:
      operationId: getInsurance
      tags: [insurance]
      summary: Get an insurance policy by building number
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: Insurance policy
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/InsurancePolicy"
        "404":
          description: Not found
    patch:
      operationId: updateInsurance
      tags: [insurance]
      summary: Update an insurance policy
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateInsuranceBody"
      responses:
        "200":
          description: Updated insurance policy
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/InsurancePolicy"
        "404":
          description: Not found

  /documents:
    get:
      operationId: listDocuments
      tags: [documents]
      summary: List all documents
      security:
        - cookieAuth: []
      parameters:
        - name: building
          in: query
          required: false
          schema:
            type: integer
        - name: unit
          in: query
          required: false
          schema:
            type: string
        - name: category
          in: query
          required: false
          schema:
            type: string
        - name: search
          in: query
          required: false
          schema:
            type: string
          description: Full-text search across name, uploader, category, and building
        - name: dateFrom
          in: query
          required: false
          schema:
            type: string
          description: Filter documents uploaded on or after this date (YYYY-MM-DD)
        - name: dateTo
          in: query
          required: false
          schema:
            type: string
          description: Filter documents uploaded on or before this date (YYYY-MM-DD)
      responses:
        "200":
          description: List of documents
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/Document"
    post:
      operationId: createDocument
      tags: [documents]
      summary: Register a document after upload
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateDocumentBody"
      responses:
        "201":
          description: Created document
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Document"

  /documents/{id}:
    get:
      operationId: getDocument
      tags: [documents]
      summary: Get a document by ID
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      responses:
        "200":
          description: Document
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Document"
        "404":
          description: Not found
    patch:
      operationId: updateDocument
      tags: [documents]
      summary: Update a document's building/unit assignment
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateDocumentBody"
      responses:
        "200":
          description: Updated document
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Document"
        "400":
          description: Invalid request
        "401":
          description: Unauthorized
        "403":
          description: Forbidden
        "404":
          description: Not found
    delete:
      operationId: deleteDocument
      tags: [documents]
      summary: Delete a document
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      responses:
        "204":
          description: Deleted
        "404":
          description: Not found

  /documents/export:
    post:
      operationId: exportDocuments
      tags: [documents]
      summary: Export selected documents as a ZIP archive
      security:
        - cookieAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/ExportDocumentsBody"
      responses:
        "200":
          description: ZIP archive of selected documents
          content:
            application/zip:
              schema:
                type: string
                format: binary
        "400":
          description: No valid documents to export
        "404":
          description: No documents found

  /documents/{id}/download:
    get:
      operationId: downloadDocument
      tags: [documents]
      summary: Get a download URL for a document
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      responses:
        "200":
          description: Download URL
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/DownloadUrlResponse"
        "404":
          description: Not found

  /storage/uploads/request-url:
    post:
      tags: [storage]
      operationId: requestUploadUrl
      summary: Request a presigned URL for file upload
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UploadUrlRequest"
      responses:
        "200":
          description: Presigned upload URL generated
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/UploadUrlResponse"
        "400":
          description: Invalid request
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorEnvelope"
        "500":
          description: Server error
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorEnvelope"

  /work-orders/{id}/upload-url:
    post:
      tags: [workOrders]
      operationId: requestWorkOrderUploadUrl
      summary: Request a presigned upload URL scoped to a work order
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UploadUrlRequest"
      responses:
        "200":
          description: Presigned upload URL generated
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/UploadUrlResponse"
        "400":
          description: Invalid request
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorEnvelope"
        "403":
          description: Access denied
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorEnvelope"
        "404":
          description: Work order not found
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/ErrorEnvelope"

  /storage/objects/{objectPath}:
    get:
      tags: [storage]
      operationId: getStorageObject
      summary: Serve an object from storage
      parameters:
        - name: objectPath
          in: path
          required: true
          schema:
            type: string
      responses:
        "200":
          description: Object content
          content:
            "*/*":
              schema:
                type: string
                format: binary
        "404":
          description: Not found

  /integrations/google-drive/status:
    get:
      operationId: getGoogleDriveStatus
      tags: [integrations]
      summary: Get Google Drive connection status
      responses:
        "200":
          description: Connection status
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/GoogleDriveStatus"

  /integrations/google-drive/connect:
    get:
      operationId: connectGoogleDrive
      tags: [integrations]
      summary: Start Google Drive OAuth flow
      responses:
        "302":
          description: Redirect to Google OAuth

  /integrations/google-drive/disconnect:
    post:
      operationId: disconnectGoogleDrive
      tags: [integrations]
      summary: Disconnect Google Drive
      responses:
        "200":
          description: Disconnected
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/GoogleDriveStatus"

  /integrations/google-drive/resync:
    post:
      operationId: resyncGoogleDrive
      tags: [integrations]
      summary: Start a background re-mirror of every document into the Drive folder tree
      security:
        - cookieAuth: []
      responses:
        "202":
          description: Sync started in background; poll /integrations/google-drive/status for progress
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/GoogleDriveResyncResult"

  /settings:
    get:
      operationId: getSettings
      tags: [settings]
      summary: Get organization settings
      responses:
        "200":
          description: Organization settings
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/OrganizationSettings"
    patch:
      operationId: updateSettings
      tags: [settings]
      summary: Update organization settings
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateSettingsBody"
      responses:
        "200":
          description: Updated organization settings
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/OrganizationSettings"

  /settings/governance:
    get:
      operationId: getGovernanceSettings
      tags: [governance]
      summary: Get governance settings (meeting notice and quorum defaults)
      security:
        - cookieAuth: []
      responses:
        "200":
          description: Governance settings
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/GovernanceSettings"
    patch:
      operationId: updateGovernanceSettings
      tags: [governance]
      summary: Update governance settings
      security:
        - cookieAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateGovernanceSettingsBody"
      responses:
        "200":
          description: Updated governance settings
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/GovernanceSettings"

  /settings/categories:
    get:
      operationId: listCategories
      tags: [settings]
      summary: List document folder categories
      responses:
        "200":
          description: List of categories
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/DocumentCategory"
    post:
      operationId: createCategory
      tags: [settings]
      summary: Create a document folder category
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateCategoryBody"
      responses:
        "201":
          description: Created category
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/DocumentCategory"

  /settings/categories/{id}:
    delete:
      operationId: deleteCategory
      tags: [settings]
      summary: Delete a document folder category
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "204":
          description: Deleted
        "404":
          description: Not found

  /settings/markers:
    get:
      operationId: listMarkers
      tags: [settings]
      summary: List map marker positions
      responses:
        "200":
          description: List of marker positions
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/MapMarker"

  /settings/markers/{buildingNum}/{view}:
    patch:
      operationId: upsertMarker
      tags: [settings]
      summary: Upsert a map marker position
      parameters:
        - name: buildingNum
          in: path
          required: true
          schema:
            type: integer
        - name: view
          in: path
          required: true
          schema:
            type: string
            enum: [plat, satellite, roadmap]
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpsertMarkerBody"
      responses:
        "200":
          description: Upserted marker
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/MapMarker"

  /notifications:
    get:
      operationId: listNotifications
      tags: [notifications]
      summary: List notifications for the current user
      security:
        - cookieAuth: []
      responses:
        "200":
          description: List of notifications
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/AppNotification"
        "401":
          description: Unauthorized

  /notifications/read-all:
    patch:
      operationId: markAllNotificationsRead
      tags: [notifications]
      summary: Mark all notifications as read
      security:
        - cookieAuth: []
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                type: object
                properties:
                  ok:
                    type: boolean
                required:
                  - ok
        "401":
          description: Unauthorized

  /notifications/{id}/read:
    patch:
      operationId: markNotificationRead
      tags: [notifications]
      summary: Mark a notification as read
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: Updated notification
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/AppNotification"
        "401":
          description: Unauthorized
        "404":
          description: Not found

  /communications/log:
    get:
      operationId: listCommunicationLog
      tags: [communications]
      summary: List sent broadcast messages
      security:
        - cookieAuth: []
      responses:
        "200":
          description: List of sent messages
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/CommunicationLogEntry"
        "401":
          description: Unauthorized
        "403":
          description: Forbidden

  /communications/broadcast:
    post:
      operationId: sendBroadcast
      tags: [communications]
      summary: Send a broadcast message to a group
      security:
        - cookieAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/BroadcastBody"
      responses:
        "201":
          description: Broadcast sent
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CommunicationLogEntry"
        "400":
          description: Bad request
        "401":
          description: Unauthorized
        "403":
          description: Forbidden

  /settings/notification-preferences:
    get:
      operationId: getNotificationPreferences
      tags: [settings]
      summary: Get current user notification preferences
      parameters:
        - name: x-user-id
          in: header
          required: false
          schema:
            type: string
      responses:
        "200":
          description: User notification preferences
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/UserNotificationPreferences"
    patch:
      operationId: updateNotificationPreferences
      tags: [settings]
      summary: Update current user notification preferences
      parameters:
        - name: x-user-id
          in: header
          required: false
          schema:
            type: string
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateNotificationPreferencesBody"
      responses:
        "200":
          description: Updated user notification preferences
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/UserNotificationPreferences"

  /reports/spend:
    get:
      operationId: getSpendReport
      tags: [reports]
      summary: Get financial spend report
      description: Returns monthly spend totals, WO volume, building breakdown, and category breakdown computed from work order history.
      parameters:
        - name: from
          in: query
          required: false
          schema:
            type: string
          description: ISO date string (YYYY-MM-DD) — start of range
        - name: to
          in: query
          required: false
          schema:
            type: string
          description: ISO date string (YYYY-MM-DD) — end of range
      responses:
        "200":
          description: Spend report data
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/SpendReport"

  /reports/spend-by-month:
    get:
      operationId: getSpendByMonth
      tags: [reports]
      summary: Monthly spend aggregates
      description: Returns total estCost grouped by month (YYYY-MM) from work order opened dates
      responses:
        "200":
          description: Monthly spend data
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/MonthlySpend"

  /billing/accounts:
    get:
      operationId: listBillingAccounts
      tags: [billing]
      summary: Manager grid view of all owner accounts with current balance
      responses:
        "200":
          description: Owner account summaries
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/OwnerAccountSummary"

  /billing/accounts/{unitId}:
    get:
      operationId: getBillingAccount
      tags: [billing]
      summary: Manager view of a single unit's ledger
      parameters:
        - name: unitId
          in: path
          required: true
          schema:
            type: string
      responses:
        "200":
          description: Owner account with full ledger
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/OwnerAccountDetail"
        "404":
          description: Unit not found

  /billing/accounts/{unitId}/entries:
    post:
      operationId: postLedgerEntry
      tags: [billing]
      summary: Post a single ledger entry to a unit's account
      parameters:
        - name: unitId
          in: path
          required: true
          schema:
            type: string
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/PostLedgerEntryBody"
      responses:
        "201":
          description: Entry created
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/LedgerEntry"

  /billing/entries/{id}:
    patch:
      operationId: updateLedgerEntry
      tags: [billing]
      summary: Edit memo on an entry (within 30 days)
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateLedgerEntryBody"
      responses:
        "200":
          description: Updated entry
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/LedgerEntry"
        "404":
          description: Not found

  /billing/entries/{id}/void:
    post:
      operationId: voidLedgerEntry
      tags: [billing]
      summary: Void a ledger entry (within 30 days). Creates a reversing void entry.
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: Voided entry (the original, marked voided)
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/LedgerEntry"
        "404":
          description: Not found

  /billing/batch-post:
    post:
      operationId: batchPostCharge
      tags: [billing]
      summary: Post one charge type to many units in one batch
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/BatchPostBody"
      responses:
        "201":
          description: Batch result
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/BatchPostResult"

  /me/account:
    get:
      operationId: getMyAccount
      tags: [billing]
      summary: Owner-facing account summary and full ledger
      responses:
        "200":
          description: Owner's account
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/OwnerAccountDetail"
        "403":
          description: Not an owner of any unit

  /me/account/statement:
    get:
      operationId: getMyAccountStatement
      tags: [billing]
      summary: PDF statement for a given period (YYYY-MM)
      parameters:
        - name: period
          in: query
          required: true
          schema:
            type: string
            description: Period in YYYY-MM format
      responses:
        "200":
          description: PDF statement
          content:
            application/pdf:
              schema:
                type: string
                format: binary
        "403":
          description: Not an owner of any unit

  /payments/config:
    get:
      operationId: getPaymentsConfig
      tags: [billing]
      summary: Get payment-related configuration (publishable key, surcharge, etc.)
      responses:
        "200":
          description: Payment config
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/PaymentsConfig"

  /me/payments/methods:
    get:
      operationId: listMyPaymentMethods
      tags: [billing]
      summary: List the current owner's saved payment methods
      responses:
        "200":
          description: Payment methods
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/OwnerPaymentMethod"

  /me/payments/setup-intent:
    post:
      operationId: createMySetupIntent
      tags: [billing]
      summary: Create a SetupIntent to save a new payment method
      responses:
        "200":
          description: Client secret for the SetupIntent
          content:
            application/json:
              schema:
                type: object
                properties:
                  clientSecret:
                    type: string
                required: [clientSecret]

  /me/payments/methods/{id}:
    delete:
      operationId: deleteMyPaymentMethod
      tags: [billing]
      summary: Remove a saved payment method
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: Removed
          content:
            application/json:
              schema:
                type: object
                properties:
                  ok:
                    type: boolean
                required: [ok]

  /me/payments/methods/{id}/auto-pay:
    post:
      operationId: setMyAutoPay
      tags: [billing]
      summary: Enable or disable auto-pay on a saved payment method
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                enabled:
                  type: boolean
              required: [enabled]
      responses:
        "200":
          description: Updated
          content:
            application/json:
              schema:
                type: object
                properties:
                  ok:
                    type: boolean
                required: [ok]

  /me/payments/intent:
    post:
      operationId: createMyPaymentIntent
      tags: [billing]
      summary: Create a one-time PaymentIntent for an owner-initiated payment
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                amountCents:
                  type: integer
                savePaymentMethod:
                  type: boolean
              required: [amountCents]
      responses:
        "200":
          description: Payment intent details
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/PaymentIntentResponse"

  /me/payments/attempts:
    get:
      operationId: listMyPaymentAttempts
      tags: [billing]
      summary: Owner's recent online payment attempts (incl. pending ACH)
      responses:
        "200":
          description: Owner payment attempts
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/MyPaymentAttempt"

  /billing/payments:
    get:
      operationId: listPaymentAttempts
      tags: [billing]
      summary: Manager list of online payment attempts
      responses:
        "200":
          description: Payment attempts
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/PaymentAttempt"

  /billing/payments/{id}/refund:
    post:
      operationId: refundPaymentAttempt
      tags: [billing]
      summary: Refund a succeeded online payment (full or partial)
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      requestBody:
        required: false
        content:
          application/json:
            schema:
              type: object
              properties:
                amountCents:
                  type: integer
                reason:
                  type: string
      responses:
        "200":
          description: Refund result
          content:
            application/json:
              schema:
                type: object
                properties:
                  ok:
                    type: boolean
                  refundId:
                    type: string
                  status:
                    type: string
                required: [ok]

  /billing/payments/{id}/receipt:
    get:
      operationId: getPaymentReceipt
      tags: [billing]
      summary: Get a Stripe receipt URL for a payment attempt
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: Receipt details
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/PaymentReceipt"

  /billing/payments/{id}/receipt/resend:
    post:
      operationId: resendPaymentReceipt
      tags: [billing]
      summary: Re-send the payment receipt email to the unit owner
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: Receipt email re-sent
          content:
            application/json:
              schema:
                type: object
                properties:
                  ok:
                    type: boolean
                  recipients:
                    type: array
                    items:
                      type: string
                required: [ok, recipients]

  /vendors:
    get:
      operationId: listVendors
      tags: [vendors]
      summary: List all vendors
      parameters:
        - name: status
          in: query
          required: false
          schema:
            type: string
      responses:
        "200":
          description: List of vendors
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/Vendor"
    post:
      operationId: createVendor
      tags: [vendors]
      summary: Create a vendor
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateVendorBody"
      responses:
        "201":
          description: Created vendor
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Vendor"

  /vendors/{id}:
    get:
      operationId: getVendor
      tags: [vendors]
      summary: Get a vendor by ID (includes work order history and spend)
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: Vendor with work order history
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/VendorDetail"
        "404":
          description: Not found
    patch:
      operationId: updateVendor
      tags: [vendors]
      summary: Update a vendor
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateVendorBody"
      responses:
        "200":
          description: Updated vendor
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/Vendor"
        "404":
          description: Not found
    delete:
      operationId: deleteVendor
      tags: [vendors]
      summary: Archive (delete) a vendor
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "204":
          description: Deleted
        "404":
          description: Not found

  /motions:
    get:
      operationId: listMotions
      tags: [motions]
      summary: List motions, optionally filtered by status or kind
      security:
        - cookieAuth: []
      parameters:
        - name: status
          in: query
          required: false
          schema:
            type: string
        - name: kind
          in: query
          required: false
          schema:
            type: string
      responses:
        "200":
          description: List of motions
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/MotionListItem"
    post:
      operationId: createMotion
      tags: [motions]
      summary: Create a motion (draft)
      security:
        - cookieAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateMotionBody"
      responses:
        "201":
          description: Created
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CreatedIdResponse"
        "400":
          description: Invalid input

  /motions/upload-url:
    post:
      operationId: requestMotionUploadUrl
      tags: [motions]
      summary: Request a presigned upload URL for a motion attachment
      security:
        - cookieAuth: []
      responses:
        "200":
          description: Presigned upload URL
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/MotionUploadUrlResponse"
        "500":
          description: Failed to generate upload URL

  /motions/{id}:
    get:
      operationId: getMotion
      tags: [motions]
      summary: Get full motion detail
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: Motion detail
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/MotionDetail"
        "400":
          description: Invalid id
        "404":
          description: Not found

  /motions/{id}/open:
    post:
      operationId: openMotion
      tags: [motions]
      summary: Move a draft motion to open for voting
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      requestBody:
        required: false
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/OpenMotionBody"
      responses:
        "200":
          description: Opened
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/OkResponse"
        "404":
          description: Not found
        "409":
          description: Cannot open from current status

  /motions/{id}/votes:
    post:
      operationId: castMotionVote
      tags: [motions]
      summary: Cast or change a board member's vote on an open motion
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CastMotionVoteBody"
      responses:
        "200":
          description: Vote recorded (with finalization status)
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CastMotionVoteResponse"
        "400":
          description: Invalid input
        "404":
          description: Not found
        "409":
          description: Voting closed

  /motions/{id}/withdraw:
    post:
      operationId: withdrawMotion
      tags: [motions]
      summary: Withdraw a non-terminal motion (proposer or admin)
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: Withdrawn
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/OkResponse"
        "403":
          description: Forbidden
        "404":
          description: Not found
        "409":
          description: Already terminal

  /motions/{id}/attachments:
    post:
      operationId: addMotionAttachment
      tags: [motions]
      summary: Register an uploaded file as an attachment on a motion
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/AddMotionAttachmentBody"
      responses:
        "201":
          description: Attachment registered
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CreatedIdResponse"
        "400":
          description: Invalid input
        "404":
          description: Not found
        "409":
          description: Voting has begun; attachments frozen

  /motions/{id}/attachments/{attId}:
    get:
      operationId: downloadMotionAttachment
      tags: [motions]
      summary: Download a motion attachment
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
        - name: attId
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: Attachment content
          content:
            "*/*":
              schema:
                type: string
                format: binary
        "404":
          description: Not found

  /motions/{id}/pdf:
    get:
      operationId: getMotionPdf
      tags: [motions]
      summary: Download the resolution PDF for a motion
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: PDF resolution
          content:
            application/pdf:
              schema:
                type: string
                format: binary
        "404":
          description: Not found

  /meetings:
    get:
      operationId: listMeetings
      tags: [meetings]
      summary: List meetings
      security:
        - cookieAuth: []
      parameters:
        - name: status
          in: query
          required: false
          schema:
            type: string
            description: Filter by status, or `all` for no filter
      responses:
        "200":
          description: List of meetings
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/MeetingListItem"
    post:
      operationId: createMeeting
      tags: [meetings]
      summary: Create a meeting
      security:
        - cookieAuth: []
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateMeetingBody"
      responses:
        "201":
          description: Created
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CreatedIdResponse"
        "400":
          description: Invalid input

  /meetings/{id}:
    get:
      operationId: getMeeting
      tags: [meetings]
      summary: Get full meeting detail (agenda, attendance, quorum, minutes)
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema: { type: integer }
      responses:
        "200":
          description: Meeting detail
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/MeetingDetail"
        "400":
          description: Invalid id
        "404":
          description: Not found
    patch:
      operationId: updateMeeting
      tags: [meetings]
      summary: Update a meeting
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema: { type: integer }
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/UpdateMeetingBody"
      responses:
        "200":
          description: Updated meeting detail
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/MeetingDetail"
        "400":
          description: Invalid id
        "404":
          description: Not found
    delete:
      operationId: deleteMeeting
      tags: [meetings]
      summary: Delete a scheduled (or cancelled) meeting
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
          required: true
          schema: { type: integer }
      responses:
        "204":
          description: Deleted
        "400":
          description: Invalid id
        "404":
          description: Not found
        "409":
          description: Cannot delete a meeting in its current status

  /meetings/{id}/notice:
    post:
      operationId: postMeetingNotice
