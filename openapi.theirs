        - closesAt
        - resolvedAt
        - votingRule
        - votingRuleDescription
        - tally
        - needed
        - boardMemberCount

    MotionDetail:
      type: object
      properties:
        id:
          type: integer
        kind:
          type: string
        title:
          type: string
        body:
          type: string
        bodyHash:
          type: string
          nullable: true
        votingRule:
          $ref: "#/components/schemas/MotionVotingRule"
        votingRuleDescription:
          type: string
        status:
          type: string
        outcome:
          type: string
          nullable: true
        createdByUserId:
          type: integer
          nullable: true
        createdByName:
          type: string
        createdAt:
          type: string
        openedAt:
          type: string
          nullable: true
        closesAt:
          type: string
          nullable: true
        resolvedAt:
          type: string
          nullable: true
        payload: {}
        tally:
          $ref: "#/components/schemas/MotionTally"
        needed:
          type: integer
          nullable: true
        finalizable:
          type: boolean
        boardMemberCount:
          type: integer
        votes:
          type: array
          items:
            $ref: "#/components/schemas/MotionVote"
        attachments:
          type: array
          items:
            $ref: "#/components/schemas/MotionAttachment"
      required:
        - id
        - kind
        - title
        - body
        - bodyHash
        - votingRule
        - votingRuleDescription
        - status
        - outcome
        - createdByUserId
        - createdByName
        - createdAt
        - openedAt
        - closesAt
        - resolvedAt
        - tally
        - needed
        - finalizable
        - boardMemberCount
        - votes
        - attachments

    CreateMotionBody:
      type: object
      properties:
        kind:
          type: string
        title:
          type: string
        body:
          type: string
        votingRule:
          $ref: "#/components/schemas/MotionVotingRule"
        closesAt:
          type: string
          nullable: true
        payload: {}
      required:
        - title
        - votingRule

    OpenMotionBody:
      type: object
      properties:
        closesAt:
          type: string
          nullable: true

    CastMotionVoteBody:
      type: object
      properties:
        decision:
          type: string
          enum: [approve, reject, abstain]
        comment:
          type: string
          nullable: true
      required:
        - decision

    CastMotionVoteResponse:
      type: object
      properties:
        ok:
          type: boolean
        finalized:
          type: boolean
        outcome:
          type: string
          nullable: true
      required:
        - ok
        - finalized
        - outcome

    AddMotionAttachmentBody:
      type: object
      properties:
        name:
          type: string
        storageKey:
          type: string
        size:
          type: integer
        contentType:
          type: string
      required:
        - name
        - storageKey

    MotionUploadUrlResponse:
      type: object
      properties:
        uploadURL:
          type: string
        objectPath:
          type: string
      required:
        - uploadURL
        - objectPath

    CalendarRecurrence:
      type: object
      properties:
        freq:
          type: string
          enum: [DAILY, WEEKLY, MONTHLY, YEARLY]
        interval:
          type: integer
        byday:
          type: array
          items: { type: string }
        until:
          type: string
        count:
          type: integer
      required: [freq]

    CalendarOverride:
      type: object
      properties:
        occurrenceKey: { type: string }
        cancelled: { type: boolean }
        startsAt: { type: string }
        endsAt: { type: string }
        title: { type: string }
        body: { type: string }
      required: [occurrenceKey]

    CalendarSubCalendar:
      type: object
      properties:
        id: { type: integer }
        slug: { type: string }
        name: { type: string }
        color: { type: string }
        description: { type: string, nullable: true }
        editorRoles:
          type: array
          items: { type: string }
        viewerRoles:
          type: array
          items: { type: string }
        isPublic: { type: boolean }
        isExternal: { type: boolean }
        sortOrder: { type: integer }
      required: [id, slug, name, color, editorRoles, viewerRoles, isPublic, isExternal, sortOrder]

    CalendarPrefs:
      type: object
      properties:
        visibleSubCalendars:
          type: object
          additionalProperties: { type: boolean }
        defaultView:
          type: string
        icalToken:
          type: string
          nullable: true
        icalTokenCreatedAt:
          type: string
          nullable: true
      required: [visibleSubCalendars, defaultView]

    CalendarPrefsBody:
      type: object
      properties:
        visibleSubCalendars:
          type: object
          additionalProperties: { type: boolean }
        defaultView:
          type: string

    CalendarReminder:
      type: object
