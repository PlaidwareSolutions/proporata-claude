  /calendar/meetings.ics:
    get:
      operationId: getPersonalMeetingsIcs
      tags: [meetings]
      summary: Personal meetings ICS feed (token-authenticated)
      description: Returns the ICS feed for meetings visible to the user identified by the iCal feed token. Executive sessions are hidden from non-board users.
      parameters:
        - name: token
          in: query
          required: true
          schema:
            type: string
      responses:
        "200":
          description: ICS calendar payload
          content:
            text/calendar:
              schema:
                type: string
        "401":
          description: Missing or invalid token

  /me/ical-token:
    post:
      operationId: getOrRotateMeetingsIcalToken
      tags: [meetings]
      summary: Get or rotate the user's meetings iCal feed token
      security:
        - cookieAuth: []
      requestBody:
        required: false
        content:
          application/json:
            schema:
              type: object
              properties:
                rotate:
                  type: boolean
                  description: If true, force rotation of the token even if one already exists
      responses:
        "200":
          description: Token and personal feed URL
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/MeetingsIcalTokenResponse"
        "404":
          description: Not found

  /calendar/sub-calendars:
    get:
      operationId: listCalendarSubCalendars
      tags: [calendar]
      summary: List visible sub-calendars
      responses:
        "200":
