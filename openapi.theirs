          description: OK
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/CalendarExternalFeed"
    post:
      operationId: createCalendarExternalFeed
      tags: [calendar]
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/CreateCalendarExternalFeedBody"
      responses:
        "201":
          description: Created
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CalendarExternalFeed"

  /calendar/external-feeds/{id}:
    delete:
      operationId: deleteCalendarExternalFeed
      tags: [calendar]
      parameters:
        - name: id
          in: path
          required: true
          schema: { type: integer }
      responses:
        "204": { description: Deleted }

  /api/resolutions:
    get:
      tags: [Resolutions]
      summary: List board resolutions
      description: |
        Lists resolutions wrapping motions of kind `resolution`. Supports filters
        on status (`active`, `all`, `draft`, `adopted`, `superseded`, `rescinded`),
        category, and a free-text search over title and number.
      parameters:
        - in: query
          name: status
          schema: { type: string }
        - in: query
          name: category
          schema: { type: string }
        - in: query
          name: search
          schema: { type: string }
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                type: array
                items: { $ref: "#/components/schemas/Resolution" }
    post:
      tags: [Resolutions]
      summary: Draft a new resolution
      description: |
        Drafts the underlying motion of kind `resolution`. The official HOA number
        is assigned only when the motion is adopted. Optionally records that this
        resolution will supersede an existing one.
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              required: [title, category]
              properties:
                title: { type: string }
                body: { type: string }
                category:
                  type: string
                  enum: [architectural, financial, rules, personnel, emergency, other]
                votingRule: { type: object }
                closesAt: { type: string, format: date-time, nullable: true }
                supersedesResolutionId: { type: integer }
      responses:
        "201":
          description: Created
          content:
            application/json:
              schema:
                type: object
                properties:
                  id: { type: integer }
                  motionId: { type: integer }

  /api/resolutions/{id}:
    get:
      tags: [Resolutions]
      summary: Get a resolution and its supersede chain
      parameters:
        - in: path
          name: id
          required: true
          schema: { type: integer }
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                allOf:
                  - $ref: "#/components/schemas/Resolution"
                  - type: object
                    properties:
                      supersedes:
                        nullable: true
                        type: object
                        properties:
                          id: { type: integer }
                          number: { type: string, nullable: true }
                          title: { type: string }
                      supersededBy:
                        nullable: true
                        type: object
                        properties:
                          id: { type: integer }
                          number: { type: string, nullable: true }
                          title: { type: string }
        "404": { description: Not found }

  /api/resolutions/{id}/supersede:
    post:
      tags: [Resolutions]
      summary: Mark another resolution as superseded by this one
      parameters:
        - in: path
          name: id
          required: true
          schema: { type: integer }
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              required: [targetResolutionId]
              properties:
                targetResolutionId: { type: integer }
      responses:
        "200": { description: OK }
        "404": { description: Not found }
        "409": { description: Both resolutions must be adopted }

  /api/resolutions/{id}/rescind:
    post:
      tags: [Resolutions]
      summary: Start a follow-up motion to rescind this resolution
      description: |
        Drafts a motion of kind `rescind_resolution`. The resolution becomes
        Rescinded only when that motion is adopted.
      parameters:
        - in: path
          name: id
          required: true
          schema: { type: integer }
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              properties:
                reason: { type: string }
                votingRule: { type: object }
                closesAt: { type: string, format: date-time, nullable: true }
      responses:
        "201":
          description: Created
          content:
            application/json:
              schema:
                type: object
                properties:
                  motionId: { type: integer }

  /api/resolutions/{id}/pdf:
    get:
      operationId: getResolutionPdf
      tags: [Resolutions]
      summary: Download the adopted-resolution PDF
      parameters:
        - in: path
          name: id
          required: true
          schema: { type: integer }
      responses:
        "200":
          description: PDF stream
          content:
            application/pdf:
              schema:
                type: string
                format: binary
        "404":
          description: Not adopted yet or PDF missing

  /api/resolutions-meta/categories:
    get:
      tags: [Resolutions]
      summary: List supported resolution categories
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                type: array
                items: { type: string }

  /amenities:
    get:
      operationId: listAmenities
