              $ref: "#/components/schemas/SetCalendarRsvpBody"
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CalendarRsvpSummary"
    delete:
      operationId: clearCalendarRsvp
      tags: [calendar]
      summary: Clear my RSVP for an event occurrence
      parameters:
        - name: id
          in: path
          required: true
          schema: { type: integer }
        - name: occurrenceKey
          in: query
          required: false
          schema: { type: string }
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CalendarRsvpSummary"

  /calendar/events/{id}/rsvps:
    get:
      operationId: listCalendarRsvps
      tags: [calendar]
      summary: List RSVPs for an event
      parameters:
        - name: id
          in: path
          required: true
          schema: { type: integer }
        - name: occurrenceKey
          in: query
          required: false
          schema: { type: string }
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CalendarRsvpSummary"

  /calendar/external-feeds:
    get:
      operationId: listCalendarExternalFeeds
      tags: [calendar]
      responses:
