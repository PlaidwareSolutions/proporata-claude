      responses:
        "204": { description: Deleted }

  /calendar/resources:
    get:
      operationId: listCalendarResources
      tags: [calendar]
      summary: List bookable resources
      responses:
        "200":
          description: OK
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: "#/components/schemas/CalendarResource"
    post:
      operationId: createCalendarResource
      tags: [calendar]
      summary: Create a bookable resource (manager only)
      requestBody:
