          description: Not found

  /meetings/{id}/agenda-packet.pdf:
    get:
      operationId: getMeetingAgendaPacketPdf
      tags: [meetings]
      summary: Download the meeting agenda packet PDF
      security:
        - cookieAuth: []
      parameters:
        - name: id
          in: path
