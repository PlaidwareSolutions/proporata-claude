        id: { type: integer }
        eventId: { type: integer }
        instanceStartsAt: { type: string }
        leadMinutes: { type: integer }
        channelInApp: { type: boolean }
        channelEmail: { type: boolean }
        channelSms: { type: boolean }
        userId:
          type: integer
          nullable: true
        dispatchedAt:
          type: string
          nullable: true
      required: [id, eventId, instanceStartsAt, leadMinutes, channelInApp, channelEmail, channelSms]

    CalendarReminderInput:
      type: object
      properties:
        leadMinutes: { type: integer }
        channelInApp: { type: boolean }
        channelEmail: { type: boolean }
        channelSms: { type: boolean }
      required: [leadMinutes]

    CalendarAttachment:
