        url: { type: string }
        enabled: { type: boolean }
        lastFetchedAt: { type: string, nullable: true }
        lastError: { type: string, nullable: true }
        lastEventCount: { type: integer }
        createdAt: { type: string }
      required: [id, subCalendarId, name, url, enabled, lastEventCount, createdAt]

    CreateCalendarExternalFeedBody:
      type: object
      properties:
        name: { type: string }
        url: { type: string }
        subCalendarSlug: { type: string }
      required: [name, url]

    GovernanceSettings:
      type: object
      properties:
        noticeOpenDays: { type: integer }
        noticeExecutiveDays: { type: integer }
        noticeAnnualDays: { type: integer }
        quorumMode:
          type: string
          enum: [majority, percent, all]
        quorumPercentBp: { type: integer }
      required: [noticeOpenDays, noticeExecutiveDays, noticeAnnualDays, quorumMode, quorumPercentBp]

    UpdateGovernanceSettingsBody:
      type: object
      properties:
        noticeOpenDays: { type: integer, minimum: 0 }
        noticeExecutiveDays: { type: integer, minimum: 0 }
        noticeAnnualDays: { type: integer, minimum: 0 }
        quorumMode:
          type: string
          enum: [majority, percent, all]
        quorumPercentBp:
          type: integer
          minimum: 0
          maximum: 10000

    MeetingQuorumState:
      type: object
      properties:
        required: { type: integer }
        attending: { type: integer }
        met: { type: boolean }
        boardSize: { type: integer }
        mode: { type: string }
        percentBp: { type: integer }
      required: [required, attending, met, boardSize, mode, percentBp]

    MeetingListItem:
      type: object
      properties:
        id: { type: integer }
        kind:
          type: string
          enum: [open, executive, annual]
        title: { type: string }
        scheduledAt: { type: string, format: date-time }
        status:
          type: string
          enum: [scheduled, in_progress, adjourned, cancelled]
        minutesStatus: { type: string }
        durationMinutes: { type: integer }
        locationPhysical: { type: string, nullable: true }
        locationVideoLink: { type: string, nullable: true }
        noticePostedAt: { type: string, format: date-time, nullable: true }
        quorum:
          $ref: "#/components/schemas/MeetingQuorumState"
        createdByName: { type: string, nullable: true }
        createdAt: { type: string, format: date-time }
      required: [id, kind, title, scheduledAt, status, minutesStatus, quorum]

    MeetingMotionSummary:
      type: object
      properties:
        id: { type: integer }
        kind: { type: string }
        title: { type: string }
        status: { type: string }
        outcome: { type: string, nullable: true }
        votingRule: { type: object }
        votingRuleDescription: { type: string }
        tally:
          type: object
          properties:
            approve: { type: integer }
            reject: { type: integer }
            abstain: { type: integer }
        needed: { type: integer }
        finalizable: { type: boolean }

    MeetingAgendaItem:
      type: object
      properties:
        id: { type: integer }
        sortOrder: { type: integer }
        kind:
          type: string
          enum: [discussion, motion, report, break]
        title: { type: string }
        notes: { type: string, nullable: true }
        motionId: { type: integer, nullable: true }
        presenter: { type: string, nullable: true }
        itemMinutes: { type: string, nullable: true }
        motion:
          allOf:
            - $ref: "#/components/schemas/MeetingMotionSummary"
          nullable: true
      required: [id, sortOrder, kind, title]

    MeetingAttendanceEntry:
      type: object
      properties:
        id: { type: integer }
        userId: { type: integer }
        userName: { type: string }
        status:
          type: string
          enum: [present, remote, absent, excused]
        isBoardMember: { type: boolean }
        recordedAt: { type: string, format: date-time }
      required: [id, userId, userName, status, isBoardMember, recordedAt]

    MeetingDetail:
      type: object
      properties:
        id: { type: integer }
        kind:
          type: string
          enum: [open, executive, annual]
        title: { type: string }
        scheduledAt: { type: string, format: date-time }
        durationMinutes: { type: integer }
        locationPhysical: { type: string, nullable: true }
        locationVideoLink: { type: string, nullable: true }
        noticeText: { type: string, nullable: true }
        noticePostedAt: { type: string, format: date-time, nullable: true }
        noticeRequiredDays: { type: integer }
        noticeOk: { type: boolean }
        status:
          type: string
          enum: [scheduled, in_progress, adjourned, cancelled]
        startedAt: { type: string, format: date-time, nullable: true }
        adjournedAt: { type: string, format: date-time, nullable: true }
        minutesContent: { type: string, nullable: true }
        minutesStatus: { type: string }
        minutesAdoptionMotionId: { type: integer, nullable: true }
        minutesAdoptedAt: { type: string, format: date-time, nullable: true }
        createdByName: { type: string, nullable: true }
        createdAt: { type: string, format: date-time }
        quorum:
          $ref: "#/components/schemas/MeetingQuorumState"
        agenda:
          type: array
          items:
            $ref: "#/components/schemas/MeetingAgendaItem"
        attendance:
          type: array
          items:
            $ref: "#/components/schemas/MeetingAttendanceEntry"
      required: [id, kind, title, scheduledAt, status, minutesStatus, quorum, agenda, attendance]

    CreateMeetingBody:
      type: object
      properties:
        kind:
          type: string
          enum: [open, executive, annual]
          default: open
        title: { type: string }
        scheduledAt: { type: string, format: date-time }
        durationMinutes: { type: integer, minimum: 15 }
        locationPhysical: { type: string, nullable: true }
        locationVideoLink: { type: string, nullable: true }
        noticeText: { type: string }
      required: [title, scheduledAt]

    UpdateMeetingBody:
      type: object
      properties:
        title: { type: string }
        kind:
          type: string
          enum: [open, executive, annual]
        scheduledAt: { type: string, format: date-time }
        durationMinutes: { type: integer, minimum: 15 }
        locationPhysical: { type: string, nullable: true }
        locationVideoLink: { type: string, nullable: true }
        noticeText: { type: string }
        minutesContent: { type: string }
        quorumMode:
          type: string
          enum: [majority, percent, all]
        quorumPercentBp:
          type: integer
          minimum: 0
          maximum: 10000
        status:
          type: string
          enum: [scheduled, in_progress, adjourned, cancelled]

    CreateMeetingAgendaItemBody:
      type: object
      properties:
        kind:
          type: string
          enum: [discussion, motion, report, break]
          default: discussion
        title: { type: string }
        notes: { type: string }
        motionId: { type: integer }
        presenter: { type: string }
      required: [title]

    UpdateMeetingAgendaItemBody:
      type: object
      properties:
        title: { type: string }
        kind:
          type: string
          enum: [discussion, motion, report, break]
        notes: { type: string, nullable: true }
        presenter: { type: string, nullable: true }
        motionId: { type: integer, nullable: true }
        itemMinutes: { type: string }
        sortOrder: { type: integer }

    ReorderMeetingAgendaBody:
      type: object
      properties:
        itemIds:
          type: array
          items: { type: integer }
      required: [itemIds]

    RecordMeetingAttendanceBody:
      type: object
      properties:
        userId: { type: integer }
        status:
          type: string
          enum: [present, remote, absent, excused]
      required: [userId, status]

    MeetingAttendanceResponse:
      type: object
      properties:
        ok: { type: boolean }
        quorum:
          $ref: "#/components/schemas/MeetingQuorumState"
      required: [ok, quorum]

    ProposeMeetingMinutesBody:
      type: object
      properties:
        adoptionMeetingId: { type: integer }
      required: [adoptionMeetingId]

    ProposeMeetingMinutesResponse:
      type: object
      properties:
        ok: { type: boolean }
        motionId: { type: integer }
      required: [ok, motionId]

    MeetingsIcalTokenResponse:
      type: object
      properties:
        token: { type: string }
        url: { type: string }
      required: [token, url]
