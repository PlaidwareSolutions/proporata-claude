      responses:
        "201":
          description: Created
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/CalendarAttachment"

  /calendar/events/{id}/attachments/{attId}:
    delete:
      operationId: deleteCalendarAttachment
      tags: [calendar]
      parameters:
        - name: id
          in: path
          required: true
          schema: { type: integer }
        - name: attId
          in: path
          required: true
