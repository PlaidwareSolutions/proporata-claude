          description: OK
          content:
            application/json:
              schema:
                type: object
                properties:
                  uploadURL: { type: string }
                required: [uploadURL]

  /calendar/events/{id}/attachments:
    post:
      operationId: registerCalendarAttachment
      tags: [calendar]
      summary: Register a completed attachment upload
      parameters:
        - name: id
          in: path
          required: true
